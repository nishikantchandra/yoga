# Frontend env vars (Vite reads VITE_* prefixed values at build time)

# Optional: backend API URL.
# Leave UNSET to run fully offline (localStorage only). The app works either way.
# Local dev:   VITE_API_URL=http://localhost:3001
# Production:  VITE_API_URL=https://api.yourdomain.com
VITE_API_URL=
